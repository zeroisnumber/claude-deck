{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CLI Deck",
  "version": "0.3.1",
  "identifier": "com.user.cli-deck",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "CLI Deck",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 600,
        "backgroundColor": "#1f1e1b",
        "dragDropEnabled": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico", "icons/icon.png"],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installerHooks": "installer-hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc0RENGNDg4RjZGMkY2MDgKUldRSTl2TDJpUFRjZFBaYUlocW9USFljQVM1SkFUd3Mva1h3d2ZVNzgyWlN3bmJmZHJhdGI4VUwK",
      "endpoints": [
        "https://github.com/zeroisnumber/claude-deck/releases/latest/download/latest.json"
      ]
    }
  }
}
